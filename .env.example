# Configuration du bot DeFi Stablecoin

# URLs RPC du réseau L2 séparées par des virgules (ex: pour le failover RPC)
L2_RPC_URLS=https://arb1.arbitrum.io/rpc,https://arbitrum.llamarpc.com
# URL RPC unique de repli historique
L2_RPC_URL=https://arb1.arbitrum.io/rpc

# --- OpSec : Ségrégation de Portefeuilles ---
# Hot Wallet : Le bot qui soumet les transactions et paie le gaz (nécessite ETH de gaz)
HOT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
# Clé privée du Hot Wallet (optionnel, uniquement requis pour de vrai signatures on-chain)
HOT_WALLET_PRIVATE_KEY=

# Cold Wallet : Votre Ledger / Safe Multisig qui détient les mooTokens de Beefy
COLD_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Adresse du vault Beefy Finance avec lequel interagir (Exemple: mooSiloUSDC sur Arbitrum)
DEFI_VAULT_ADDRESS=0x83152eE78d8f20Bba134A5FF000D551355Ce3996

# Mode simulation (true = dry-run sans exécution de transactions réelles)
SIMULATION_MODE=true

# --- Authentification API Dashboard ---
# Clé API pour protéger les endpoints d'administration du dashboard (trigger-check, simulate-depeg, logs, status)
# Générez une clé aléatoire forte : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# --- Notifications (optionnel) ---
# Webhook Discord pour les alertes
DISCORD_WEBHOOK_URL=
# Telegram Bot Token et Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
